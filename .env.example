# Сервер приёма заявок (/api/lead)
# Куда прилетают формы «Начни сейчас» и waitlist-подписки.

# --- Telegram (рекомендуется) ---
# 1. В @BotFather создай бота → получи TELEGRAM_BOT_TOKEN
# 2. Добавь бота в личный чат / канал / группу
# 3. Открой https://api.telegram.org/bot<TOKEN>/getUpdates — возьми id чата
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Опциональный дополнительный webhook ---
# Годится под Formspree / Getform / Google Apps Script / Make.com / n8n
LEAD_WEBHOOK_URL=
